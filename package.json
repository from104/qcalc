{
  "name": "qcalc",
  "version": "0.11.6",
  "description": "com.atit.qcalc",
  "productName": "Q Calc",
  "desktopName": "com.atit.qcalc.desktop",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/from104/qcalc.git"
  },
  "author": {
    "name": "Seo Kihyun",
    "email": "from104@gmail.com",
    "url": "https://github.com/from104"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/from104/qcalc/issues"
  },
  "homepage": "https://github.com/from104/qcalc#readme",
  "keywords": [
    "calculator",
    "quasar",
    "vue",
    "electron",
    "typescript"
  ],
  "type": "module",
  "scripts": {
    "postinstall": "quasar prepare",
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,mjs,cjs,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "yarn node --experimental-vm-modules $(yarn bin jest)",
    "dev": "quasar dev -m electron",
    "dev:android": "quasar dev -m capacitor -T android",
    "build": "quasar build -m electron",
    "build:win32": "quasar build -m electron -T win32",
    "build:android": "quasar build -m capacitor -T android",
    "build:flatpak": "cd flatpak && bash build-flatpak.sh install",
    "icons": "icongenie g -m spa,electron -i ./assets/qcalc_icon_v3.png; icongenie g -m capacitor -i ./assets/qcalc_icon_v3.png --skip-trim; rm -r src-capacitor/ios"
  },
  "exports": {
    "./src/boot/*": "./src/boot/*.ts"
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "7.6.0",
    "@capacitor/app": "7.1.2",
    "@capacitor/cli": "7.6.0",
    "@capacitor/core": "7.6.0",
    "@capacitor/filesystem": "7.1.8",
    "@capacitor/haptics": "7.0.4",
    "@capacitor/screen-orientation": "7.0.4",
    "@capacitor/share": "^7.0.4",
    "@capacitor/status-bar": "7.0.5",
    "@everapi/freecurrencyapi-js": "^1.0.1",
    "@intlify/unplugin-vue-i18n": "11.1.0",
    "@quasar/cli": "2.5.0",
    "@quasar/extras": "1.17.0",
    "@quasar/quasar-ui-qmarkdown": "^2.0.5",
    "@quasar/vite-plugin": "1.10.0",
    "@types/dompurify": "3.2.0",
    "@vitejs/plugin-vue": "6.0.4",
    "axios": "1.13.6",
    "dotenv": "17.3.1",
    "electron-log": "5.4.3",
    "electron-updater": "6.8.3",
    "electron-window-state": "^5.0.3",
    "mathjs": "15.1.1",
    "papaparse": "^5.5.3",
    "pinia": "3.0.4",
    "pinia-plugin-persistedstate": "4.7.1",
    "quasar": "2.18.6",
    "tinykeys": "^3.0.0",
    "ts-pattern": "5.9.0",
    "vite-plugin-env-types": "^0.1.4",
    "vue": "3.5.29",
    "vue-i18n": "11.2.8",
    "vue-router": "4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@modyfi/vite-plugin-yaml": "1.1.1",
    "@quasar/app-vite": "2.4.1",
    "@quasar/quasar-app-extension-qmarkdown": "^2.0.5",
    "@rushstack/eslint-patch": "1.16.1",
    "@types/node": "24.12.0",
    "@types/papaparse": "^5.5.2",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@vue/devtools": "8.0.7",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.7.0",
    "autoprefixer": "10.4.27",
    "electron": "35.7.5",
    "electron-builder": "26.8.2",
    "eslint": "9.39.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-vue": "10.8.0",
    "globals": "16.5.0",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "sass": "1.97.3",
    "tslib": "^2.8.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-checker": "0.12.0",
    "vue-eslint-parser": "10.4.0",
    "vue-tsc": "3.2.5"
  },
  "engines": {
    "node": ">=20",
    "npm": ">= 6.13.4",
    "yarn": ">= 4.5.1"
  },
  "resolutions": {
    "wrap-ansi": "7.0.0",
    "string-width": "4.1.0",
    "ansi-regex": "5.0.1",
    "strip-ansi": "6.0.1"
  },
  "packageManager": "yarn@4.10.3"
}
