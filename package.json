{
  "name": "qcalc",
  "version": "0.12.0",
  "description": "io.github.from104.qcalc",
  "productName": "Q Calc",
  "desktopName": "io.github.from104.qcalc.desktop",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/from104/qcalc.git"
  },
  "author": {
    "name": "Seo Kihyun",
    "email": "from104@gmail.com",
    "url": "https://github.com/from104"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/from104/qcalc/issues"
  },
  "homepage": "https://github.com/from104/qcalc#readme",
  "keywords": ["calculator", "quasar", "vue", "electron", "typescript"],
  "type": "module",
  "scripts": {
    "postinstall": "quasar prepare",
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,mjs,cjs,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "fetch-rates": "tsx scripts/fetch-fallback-rates.ts",
    "dev": "quasar dev -m electron",
    "dev:android": "quasar dev -m capacitor -T android",
    "build": "quasar build -m electron",
    "build:win32": "quasar build -m electron -T win32",
    "build:android": "quasar build -m capacitor -T android",
    "build:flatpak": "cd flatpak && bash build-flatpak.sh build",
    "icons": "icongenie g -m spa,electron -i ./assets/qcalc_icon_v3.png; icongenie g -m capacitor -i ./assets/qcalc_icon_v3.png --skip-trim; rm -r src-capacitor/ios",
    "prepare": "husky"
  },
  "exports": {
    "./src/boot/*": "./src/boot/*.ts"
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "8.2.0",
    "@capacitor/app": "8.0.1",
    "@capacitor/cli": "8.2.0",
    "@capacitor/core": "8.2.0",
    "@capacitor/filesystem": "8.1.2",
    "@capacitor/haptics": "8.0.1",
    "@capacitor/screen-orientation": "8.0.1",
    "@capacitor/share": "8.0.1",
    "@capacitor/status-bar": "8.0.1",
    "@intlify/unplugin-vue-i18n": "11.1.0",
    "@quasar/cli": "2.5.0",
    "@quasar/extras": "1.17.0",
    "@quasar/quasar-ui-qmarkdown": "^2.0.5",
    "@quasar/vite-plugin": "1.11.0",
    "@types/dompurify": "3.0.5",
    "@vitejs/plugin-vue": "6.0.5",
    "axios": "1.13.6",
    "dotenv": "17.3.1",
    "electron-log": "5.4.3",
    "electron-updater": "6.8.3",
    "electron-window-state": "^5.0.3",
    "mathjs": "15.1.1",
    "papaparse": "^5.5.3",
    "pinia": "3.0.4",
    "pinia-plugin-persistedstate": "4.7.1",
    "quasar": "2.18.7",
    "tinykeys": "^3.0.0",
    "ts-pattern": "5.9.0",
    "vite-plugin-env-types": "^0.1.4",
    "vue": "3.5.30",
    "vue-i18n": "11.3.0",
    "vue-router": "5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@modyfi/vite-plugin-yaml": "1.1.1",
    "@pinia/testing": "^1.0.3",
    "@quasar/app-vite": "2.5.2",
    "@quasar/quasar-app-extension-qmarkdown": "^2.0.5",
    "@rushstack/eslint-patch": "1.16.1",
    "@types/node": "25.5.0",
    "@types/papaparse": "^5.5.2",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "@vitest/coverage-v8": "4.1.0",
    "@vue/devtools": "8.1.0",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "10.4.27",
    "axe-core": "^4.11.1",
    "electron": "^41.0.3",
    "electron-builder": "26.8.2",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-vue": "10.8.0",
    "globals": "17.4.0",
    "husky": "^9.1.7",
    "jsdom": "29.0.1",
    "lint-staged": "16.4.0",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "sass": "1.98.0",
    "tslib": "^2.8.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "8",
    "vite-plugin-checker": "0.12.0",
    "vitest": "4.1.0",
    "vitest-axe": "^0.1.0",
    "vue-eslint-parser": "10.4.0",
    "vue-tsc": "3.2.6"
  },
  "engines": {
    "node": ">=20",
    "npm": ">= 6.13.4",
    "yarn": ">= 4.5.1"
  },
  "resolutions": {
    "wrap-ansi": "7.0.0",
    "string-width": "4.1.0",
    "ansi-regex": "5.0.1",
    "strip-ansi": "6.0.1"
  },
  "packageManager": "yarn@4.10.3",
  "lint-staged": {
    "*.{ts,js,cjs,mjs,vue}": ["eslint -c ./eslint.config.js --fix"],
    "*.{ts,js,cjs,mjs,vue,scss,html,md,json}": ["prettier --write"]
  }
}
